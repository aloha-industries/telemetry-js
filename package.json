{
  "name": "@aloha-industries/telemetry-js",
  "version": "0.1.0",
  "description": "Privacy-first browser event tracker. Captures search and click events with stateless, anonymous payloads \u2014 no cookies, no auth tokens, no identifiers.",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "sideEffects": false,
  "main": "./dist/tracker.umd.js",
  "module": "./dist/tracker.esm.js",
  "exports": {
    ".": {
      "import": "./dist/tracker.esm.js",
      "require": "./dist/tracker.umd.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "size": "size-limit"
  },
  "keywords": [
    "telemetry",
    "analytics",
    "privacy",
    "anonymous",
    "tracker"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@size-limit/preset-small-lib": "^11.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "jsdom": "^25.0.0",
    "size-limit": "^11.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "size-limit": [
    {
      "path": "dist/tracker.esm.js",
      "limit": "1 KB"
    }
  ]
}
